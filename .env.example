# ============================================
# Tawafud AI Medical Receptionist
# Environment Variables Template
# ============================================
# Copy this file to .env and fill in your actual values
# SECURITY: Never commit .env to version control!
# ============================================

# ──────────────────────────────────────────
# Database Configuration
# ──────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=hospital_booking
POSTGRES_PORT=5432

# Database URL (auto-constructed in docker-compose, but needed for local dev)
DATABASE_URL=postgresql://app:CHANGE_ME_STRONG_PASSWORD_HERE@localhost:5432/hospital_booking?schema=public

# ──────────────────────────────────────────
# Backend Server Configuration
# ──────────────────────────────────────────
BACKEND_PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# ──────────────────────────────────────────
# Security & Authentication
# ──────────────────────────────────────────
# JWT Secret - Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64

# CORS - Comma-separated list of allowed origins
CORS_ORIGIN=https://your-domain.com,https://www.your-domain.com

# Webhook API Key - Generate with: openssl rand -hex 32
WEBHOOK_API_KEY=CHANGE_ME_RANDOM_SECURE_KEY

# ──────────────────────────────────────────
# OpenAI Configuration
# ──────────────────────────────────────────
OPENAI_API_KEY=sk-proj-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ──────────────────────────────────────────
# Google Gemini Configuration
# ──────────────────────────────────────────
GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ──────────────────────────────────────────
# Public URLs (Production)
# ──────────────────────────────────────────
# Base URL - Your production domain
BASE_URL=https://your-domain.com

# ──────────────────────────────────────────
# Organization Configuration
# ──────────────────────────────────────────
# Default organization UUID (create this in the database)
DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000

# ──────────────────────────────────────────
# Frontend Configuration
# ──────────────────────────────────────────
FRONTEND_PORT=80

# Vite environment variables (for frontend build)
VITE_API_URL=https://your-domain.com/api
VITE_APP_NAME=Tawafud

# ──────────────────────────────────────────
# Nginx Configuration
# ──────────────────────────────────────────
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ──────────────────────────────────────────
# Optional: n8n Workflow Automation
# ──────────────────────────────────────────
# Uncomment these if using n8n
# N8N_POSTGRES_PASSWORD=CHANGE_ME_N8N_PASSWORD
# N8N_PORT=5678
# N8N_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_KEY

# ──────────────────────────────────────────
# Optional: Redis (for session management)
# ──────────────────────────────────────────
# REDIS_PORT=6379
# REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD
# REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────────
# Development-Only Variables
# ──────────────────────────────────────────
# These are only needed for local development
# DEV_DATABASE_URL=postgresql://app:password@localhost:5432/hospital_booking_dev?schema=public
