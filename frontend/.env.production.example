# ============================================
# Tawafud Frontend — Production Environment
# Copy to .env.production and fill in values
# ============================================

# Backend API URL (empty = same origin, uses Vite proxy in dev)
# In production, set to your backend URL if frontend is on a different domain
VITE_API_URL=

# Example for separate domain deployment:
# VITE_API_URL=https://api.your-domain.com

# Clinic phone number shown in patient portal (leave empty to hide the call button)
VITE_CLINIC_PHONE=
