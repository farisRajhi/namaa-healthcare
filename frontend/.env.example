# ============================================
# Tawafud Frontend — Local Development Environment
# Copy to .env and fill in values. .env is gitignored.
# ============================================

# Backend API URL (empty = same origin, uses Vite proxy in dev)
VITE_API_URL=

# Clinic phone number shown in patient portal (leave empty to hide the call button)
VITE_CLINIC_PHONE=

# ============================================
# Tap Payments (REQUIRED for the Pay button to work)
# ============================================
# Public key — safe to ship to the browser. sk_test_* for sandbox.
# Get from https://dashboard.tap.company/
VITE_TAP_PUBLIC_KEY=pk_test_CHANGE_ME

# Merchant id — optional but recommended (shown on the card form).
# Can be left empty during sandbox testing.
VITE_TAP_MERCHANT_ID=
