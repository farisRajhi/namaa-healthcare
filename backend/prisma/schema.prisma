// ─── Offers (WhatsApp Marketing) ────────────────────────────

model Offer {
  offerId         String            @id @default(dbgenerated("gen_random_uuid()")) @map("offer_id") @db.Uuid
  orgId           String            @map("org_id") @db.Uuid
  name            String
  nameAr          String?           @map("name_ar")
  description     String?
  descriptionAr   String?           @map("description_ar")

  // Offer mechanics
  offerType       String            @map("offer_type") // percentage_discount, fixed_discount, free_addon, bundle, loyalty_reward
  discountValue   Int?              @map("discount_value") // percentage (e.g. 20) or fixed amount in halalas
  discountUnit    String?           @map("discount_unit") // percent | sar
  promoCode       String?           @unique @map("promo_code")

  // Scope
  serviceIds      String[]          @map("service_ids") @db.Uuid
  providerIds     String[]          @map("provider_ids") @db.Uuid
  facilityIds     String[]          @map("facility_ids") @db.Uuid

  // Validity
  validFrom       DateTime          @map("valid_from") @db.Timestamptz(6)
  validUntil      DateTime          @map("valid_until") @db.Timestamptz(6)
  maxRedemptions  Int?              @map("max_redemptions")
  perPatientLimit Int               @default(1) @map("per_patient_limit")

  // Targeting
  targetPreset    String?           @map("target_preset") // lapsed_90, lapsed_180, high_value, new_patient, care_gap, at_risk, birthday_month, custom
  targetFilter    Json              @default("{}") @map("target_filter")

  // Status
  status          String            @default("draft") // draft, active, paused, expired, archived

  // Messaging
  messageAr       String?           @map("message_ar")
  messageEn       String?           @map("message_en")

  // Analytics (denormalized)
  totalSent       Int               @default(0) @map("total_sent")
  totalRedeemed   Int               @default(0) @map("total_redeemed")
  totalRevenue    Int               @default(0) @map("total_revenue") // in halalas

  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  redemptions     OfferRedemption[]
  campaigns       Campaign[]

  @@index([orgId, status])
  @@index([promoCode])
  @@index([orgId, validUntil])
  @@map("offers")
}

model OfferRedemption {
  redemptionId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("redemption_id") @db.Uuid
