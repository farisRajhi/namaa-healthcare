  @@unique([orgId, key])
  @@index([orgId])
  @@map("whatsapp_session_keys")
}

// ─── Service Cycle Suggestions ─────────────────────────────

model ServiceCycleSuggestion {
  suggestionId   String    @id @default(dbgenerated("gen_random_uuid()")) @map("suggestion_id") @db.Uuid
  orgId          String    @map("org_id") @db.Uuid
  patientId      String    @map("patient_id") @db.Uuid
  serviceId      String    @map("service_id") @db.Uuid

  score          Int       @default(50)
  suggestionType String    @map("suggestion_type")

  lastCompletedAt DateTime? @map("last_completed_at") @db.Timestamptz(6)
  dueAt          DateTime  @map("due_at") @db.Timestamptz(6)
  overdueDays    Int       @default(0) @map("overdue_days")

  messageAr      String?   @map("message_ar")
  messageEn      String?   @map("message_en")

  status         String    @default("pending")
  sentAt         DateTime? @map("sent_at") @db.Timestamptz(6)
  sentBy         String?   @map("sent_by")

  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  patient        Patient   @relation(fields: [patientId], references: [patientId], onDelete: Cascade)
  service        Service   @relation(fields: [serviceId], references: [serviceId], onDelete: Cascade)

  @@unique([patientId, serviceId, status])
  @@index([orgId, score(sort: Desc)])
  @@index([orgId, status])
  @@map("service_cycle_suggestions")
}

// ─── Patient Intelligence (External DB Analysis) ─────────────

model ExternalAnalysis {
  analysisId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("analysis_id") @db.Uuid
  orgId          String    @map("org_id") @db.Uuid

  // Upload metadata
  fileName       String    @map("file_name")
  fileSize       Int       @map("file_size")
  rowCount       Int       @default(0) @map("row_count")

  // AI-detected metadata
  clinicType     String?   @map("clinic_type")
  columnMapping  Json?     @map("column_mapping")
  dataQuality    Json?     @map("data_quality")

  // Processing
  status         String    @default("uploading")
  currentStep    String?   @map("current_step")
  progress       Int       @default(0)
  errorMessage   String?   @map("error_message")

  // Results summary
  totalPatients    Int     @default(0) @map("total_patients")
  patientsAnalyzed Int     @default(0) @map("patients_analyzed")
  suggestionsCount Int     @default(0) @map("suggestions_count")

  // AI cost tracking
  tokensUsed     Int       @default(0) @map("tokens_used")
  aiCalls        Int       @default(0) @map("ai_calls")
  skillsLoaded   String[]  @map("skills_loaded")

  createdBy      String?   @map("created_by") @db.Uuid
  startedAt      DateTime? @map("started_at") @db.Timestamptz(6)
  completedAt    DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  patients       ExternalPatient[]
  suggestions    AICampaignSuggestion[]

  @@index([orgId, status])
  @@index([orgId, createdAt(sort: Desc)])
  @@map("external_analyses")
}

model ExternalPatient {
  externalPatientId String  @id @default(dbgenerated("gen_random_uuid()")) @map("external_patient_id") @db.Uuid
  analysisId        String  @map("analysis_id") @db.Uuid
  orgId             String  @map("org_id") @db.Uuid

  // Normalized fields from CSV
  name              String?
  nameAr            String? @map("name_ar")
  phone             String?
  email             String?
  dateOfBirth       DateTime? @map("date_of_birth") @db.Date
  sex               String?

  // Clinical data
  lastVisitDate     DateTime? @map("last_visit_date") @db.Date
  lastService       String?   @map("last_service")
  lastServiceAr     String?   @map("last_service_ar")
  totalVisits       Int       @default(0) @map("total_visits")
  services          String[]

  // External system reference
  externalId        String?   @map("external_id")

  // AI analysis results
  aiScore           Int?      @map("ai_score")
  aiReasoning       String?   @map("ai_reasoning")
  aiSegment         String?   @map("ai_segment")
  aiSuggestedAction String?   @map("ai_suggested_action")

  // Match to existing system patient
  matchedPatientId  String?   @map("matched_patient_id") @db.Uuid
  matchConfidence   Float?    @map("match_confidence")

  // Contact history from existing system
  previousCampaigns Int       @default(0) @map("previous_campaigns")
  lastCampaignDate  DateTime? @map("last_campaign_date") @db.Timestamptz(6)
  lastCampaignResult String?  @map("last_campaign_result")

  // Raw CSV row
  rawData           Json?     @map("raw_data")
  rowIndex          Int       @default(0) @map("row_index")

  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  analysis          ExternalAnalysis @relation(fields: [analysisId], references: [analysisId], onDelete: Cascade)

  @@index([analysisId])
  @@index([orgId, phone])
  @@index([analysisId, aiScore(sort: Desc)])
  @@map("external_patients")
}

model AICampaignSuggestion {
  suggestionId     String    @id @default(dbgenerated("gen_random_uuid()")) @map("suggestion_id") @db.Uuid
  analysisId       String    @map("analysis_id") @db.Uuid
  orgId            String    @map("org_id") @db.Uuid

  // Campaign definition
  name             String
  nameAr           String?   @map("name_ar")
  type             String
  segment          String
  segmentDescAr    String?   @map("segment_desc_ar")
  segmentDescEn    String?   @map("segment_desc_en")

  // Message content
  scriptAr         String?   @map("script_ar")
  scriptEn         String?   @map("script_en")

  // Targeting
  patientCount     Int       @default(0) @map("patient_count")
  patientIds       String[]  @map("patient_ids") @db.Uuid
  channelSequence  String[]  @map("channel_sequence")

  // AI reasoning
  reasoning        String?
  reasoningAr      String?   @map("reasoning_ar")
  expectedOutcome  String?   @map("expected_outcome")
  priority         Int       @default(50)
  confidenceScore  Float     @default(0.5) @map("confidence_score")

  // Offer recommendation
  suggestedOfferType String?  @map("suggested_offer_type")
  suggestedDiscount  Int?     @map("suggested_discount")

  // Approval workflow
  status           String    @default("pending")
  reviewedBy       String?   @map("reviewed_by") @db.Uuid
  reviewedAt       DateTime? @map("reviewed_at") @db.Timestamptz(6)
  reviewNotes      String?   @map("review_notes")

  // Link to created campaign
  campaignId       String?   @map("campaign_id") @db.Uuid
  offerId          String?   @map("offer_id") @db.Uuid

  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  analysis         ExternalAnalysis @relation(fields: [analysisId], references: [analysisId], onDelete: Cascade)

  @@index([analysisId, priority(sort: Desc)])
  @@index([orgId, status])
  @@map("ai_campaign_suggestions")
}
