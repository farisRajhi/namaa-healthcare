# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (using the app_postgres container, port 5433)
DATABASE_URL="postgresql://app:CHANGE_ME_STRONG_PASSWORD@localhost:5433/hospital_booking?schema=public"

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-key-change-in-production

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Webhook API Key (for n8n to call your backend)
WEBHOOK_API_KEY=your-webhook-api-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ============================================
# GEMINI MULTIMODAL LIVE API (Alternative to OpenAI + ElevenLabs)
# ============================================
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model (optional, defaults to gemini-2.0-flash-exp)
# GEMINI_MODEL=models/gemini-2.0-flash-exp

# Use Gemini for voice calls instead of OpenAI + ElevenLabs
# Set to 'true' to use Gemini Multimodal Live API for voice
USE_GEMINI_VOICE=true

# ============================================
# VOICE AI CONFIGURATION (Phone Calls)
# ============================================

# Twilio Configuration (required for voice)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# ElevenLabs TTS Configuration
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# Voice IDs for different Arabic dialects (optional, uses defaults if not set)
# VOICE_ID_GULF=voice-id-for-gulf-arabic
# VOICE_ID_EGYPTIAN=voice-id-for-egyptian-arabic
# VOICE_ID_LEVANTINE=voice-id-for-levantine-arabic
# VOICE_ID_MSA=voice-id-for-modern-standard-arabic

# Voice Settings
VOICE_DEFAULT_DIALECT=msa
VOICE_MAX_CALL_DURATION_SEC=600
VOICE_SILENCE_TIMEOUT_MS=1500

# Base URL for webhooks (your public domain)
BASE_URL=https://your-domain.com
VOICE_WS_URL=wss://your-domain.com/api/voice/stream

# Google Cloud Project (required for voice test with Gemini)
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Twilio WhatsApp number (optional, for WhatsApp messaging)
# TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# Development only: Skip Twilio signature verification
# SKIP_TWILIO_VERIFY=true

# Registration protection (REQUIRED in production)
REGISTRATION_TOKEN=CHANGE_ME_RANDOM_TOKEN

# Tap Payments (required for billing)
# Get keys from https://dashboard.tap.company/
# Webhook signature is verified using TAP_SECRET_KEY (Tap's hashstring header is HMAC-SHA256
# with the secret API key — no separate webhook secret env var is required).
# Saved-card auto-renewals require live keys; test keys won't successfully off-session charge.
TAP_SECRET_KEY=sk_test_CHANGE_ME
TAP_PUBLIC_KEY=pk_test_CHANGE_ME

# Frontend URL — used as the base for Tap redirect_url after 3DS
FRONTEND_URL=http://localhost:5174

# ── Platform admin seeding ──────────────────────────
# Dev only: when both vars are set, `npm run db:seed` provisions a platform admin so you can
# log in at http://localhost:5174/platform/login. Both are blocked at startup in production.
# In production, create platform admins out-of-band:
#   npm run platform:create-admin -- --email admin@tawafud.ai --name "Faris"
SEED_PLATFORM_ADMIN_EMAIL=admin@tawafud.ai
SEED_PLATFORM_ADMIN_PASSWORD=DevPassword123!
