# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# Database (using the app_postgres container, port 5433)
DATABASE_URL="postgresql://app:CHANGE_ME_STRONG_PASSWORD@localhost:5433/hospital_booking?schema=public"

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-key-change-in-production

# CORS (comma-separated origins)
CORS_ORIGIN=http://localhost:5173,http://localhost:3001

# Webhook API Key (for n8n to call your backend)
WEBHOOK_API_KEY=your-webhook-api-key-here

# OpenAI API
OPENAI_API_KEY=your-openai-api-key-here
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ============================================
# GEMINI API (used for chat AI)
# ============================================
# Get your API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Gemini Model (optional, defaults to gemini-2.0-flash-exp)
# GEMINI_MODEL=models/gemini-2.0-flash-exp

# ============================================
# ANTHROPIC (Claude) — used by Patient Intelligence
# ============================================
# Get your API key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model (optional, defaults to claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Patient Intelligence per-step LLM provider ──────────────────
# Each step can be routed to 'gemini' or 'anthropic' independently.
# Default: Gemini for all three steps (cheaper, single-provider simplicity).
# Flip any step to 'anthropic' to use Claude Sonnet (needs ANTHROPIC_API_KEY).
PATIENT_INTEL_DATA_PROVIDER=gemini
PATIENT_INTEL_ANALYZER_PROVIDER=gemini
PATIENT_INTEL_CAMPAIGN_PROVIDER=gemini

# Base URL for webhooks (your public domain)
BASE_URL=https://your-domain.com

# Registration protection (REQUIRED in production)
REGISTRATION_TOKEN=CHANGE_ME_RANDOM_TOKEN

# ============================================
# Tap Payments (REQUIRED for subscription billing)
# ============================================
# Get keys from https://dashboard.tap.company/
# Sandbox keys start with sk_test_/pk_test_; production start with sk_live_/pk_live_.
# Webhook signature is verified using TAP_SECRET_KEY (HMAC-SHA256 of the hashstring header).
# Saved-card auto-renewals require live keys — test keys cannot off-session charge.
TAP_SECRET_KEY=sk_test_CHANGE_ME
TAP_PUBLIC_KEY=pk_test_CHANGE_ME

# ============================================
# Deployment URLs (used for Tap redirect + webhook registration)
# ============================================
# Frontend URL — Tap redirects the card-holder here after 3DS auth
FRONTEND_URL=http://localhost:5174

# Backend public URL — Tap posts webhook notifications here.
# In production this MUST be the externally-reachable domain
# (e.g. https://api.tawafud.ai). Locally, use ngrok or similar.
BACKEND_URL=http://localhost:3003

# Alias for BACKEND_URL used by some handlers. Safe to leave equal.
BASE_URL=http://localhost:3003

# ── Platform admin seeding ──────────────────────────
# Dev only: when both vars are set, `npm run db:seed` provisions a platform admin so you can
# log in at http://localhost:5174/platform/login. Both are blocked at startup in production.
# In production, create platform admins out-of-band:
#   npm run platform:create-admin -- --email admin@tawafud.ai --name "Faris"
SEED_PLATFORM_ADMIN_EMAIL=admin@tawafud.ai
SEED_PLATFORM_ADMIN_PASSWORD=DevPassword123!

# ============================================
# AI ad-image generation + storage
# ============================================
# Daily generation cap per org (defaults to 30)
# AD_IMAGE_DAILY_LIMIT=30

# Object storage for logos and AI-generated ad images.
# Leave empty to fall back to local disk (backend/uploads/).
# When set, all S3_* must be provided (S3_REGION optional, default us-east-1).
# S3_BUCKET=
# S3_REGION=us-east-1
# S3_ENDPOINT=                   # optional, set for R2 / Spaces / MinIO
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_PUBLIC_URL_BASE=            # public CDN/URL prefix for served objects
