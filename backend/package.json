{
  "name": "tawafud-backend",
  "version": "1.0.0",
  "description": "Backend API for Tawafud",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:pull": "prisma db pull",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "platform:create-admin": "tsx scripts/createPlatformAdmin.ts",
    "billing:run-dunning": "tsx scripts/runDunning.ts",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:routes": "vitest run __tests__/routes",
    "test:services": "vitest run __tests__/services",
    "test:integration": "vitest run __tests__/integration",
    "test:unit": "vitest run __tests__/routes __tests__/services",
    "test:ci": "vitest run __tests__/services --exclude '**/*.integration.test.ts'",
    "test:all": "vitest run && vitest run --coverage",
    "test:legacy": "npx tsx --test tests/api.test.ts",
    "test:verbose": "npx tsx --test --test-reporter spec tests/api.test.ts"
  },
  "keywords": [
    "whatsapp",
    "booking",
    "ai-agents",
    "fastify"
  ],
  "author": "",
  "license": "ISC",
  "type": "module",
  "overrides": {
    "@whiskeysockets/libsignal-node": {
      "protobufjs": "^7.5.5"
    },
    "protobufjs": "^7.5.5"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.1037.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/formbody": "^7.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^6.12.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/websocket": "^9.0.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "@types/qrcode": "^1.5.6",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "bcryptjs": "^3.0.3",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "google-auth-library": "^10.5.0",
    "iconv-lite": "^0.7.2",
    "node-cron": "^4.2.1",
    "openai": "^6.15.0",
    "papaparse": "^5.5.3",
    "qrcode": "^1.5.4",
    "ws": "^8.18.3",
    "zod": "^3.23.8"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.2",
    "@types/node-cron": "^3.0.11",
    "@types/papaparse": "^5.5.2",
    "@types/supertest": "^6.0.3",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.6.1",
    "msw": "^2.12.10",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
