# ============================================
# Tawafud Backend — Production Environment
# Copy to .env and fill in real values
# NEVER commit .env with real credentials!
# ============================================

# ── Server ───────────────────────────────────────────
PORT=3003
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
DATABASE_URL="postgresql://app:CHANGE_ME_STRONG_PASSWORD@localhost:5434/hospital_booking?schema=public"

# ── Authentication ───────────────────────────────────
# MUST change! Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET

# ── CORS ─────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com

# ── Webhook Security ────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_API_KEY=CHANGE_ME_RANDOM_KEY

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Google Gemini (Voice AI) ─────────────────────────
GEMINI_API_KEY=your-gemini-api-key
USE_GEMINI_VOICE=true

# ── Twilio (Voice & SMS & WhatsApp) ─────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx
# TWILIO_WHATSAPP_NUMBER=whatsapp:+1234567890

# ── ElevenLabs TTS ──────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── Voice Settings ──────────────────────────────────
VOICE_DEFAULT_DIALECT=msa
VOICE_MAX_CALL_DURATION_SEC=600
VOICE_SILENCE_TIMEOUT_MS=1500

# ── Public URLs (for Twilio webhooks) ───────────────
BASE_URL=https://your-domain.com
VOICE_WS_URL=wss://your-domain.com/api/voice/stream

# ── Organization ────────────────────────────────────
DEFAULT_ORG_ID=your-org-uuid

# ── Security ────────────────────────────────────────
# MUST be false in production!
SKIP_TWILIO_VERIFY=false
