# ============================================
# Tawafud Backend — Production Environment
# Copy to .env and fill in real values
# NEVER commit .env with real credentials!
# ============================================

# ── Server ───────────────────────────────────────────
PORT=3003
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=info

# ── Database ─────────────────────────────────────────
# Generate a strong password: openssl rand -base64 32
DATABASE_URL="postgresql://app:CHANGE_ME_STRONG_PASSWORD@localhost:5434/hospital_booking?schema=public"

# ── Authentication ───────────────────────────────────
# MUST change! Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET

# ── CORS ─────────────────────────────────────────────
CORS_ORIGIN=https://your-domain.com

# ── Webhook Security ────────────────────────────────
# Generate with: openssl rand -hex 32
WEBHOOK_API_KEY=CHANGE_ME_RANDOM_KEY

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gemini-2.5-flash
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Google Gemini (chat + Patient Intelligence default) ──
GEMINI_API_KEY=your-gemini-api-key

# ── Anthropic Claude (Patient Intelligence campaign generation) ──
ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Patient Intelligence per-step LLM provider ─────────────
# Each step independently: 'gemini' or 'anthropic'.
# Default: Gemini for all three steps. Flip any step to 'anthropic' to use
# Claude Sonnet (needs ANTHROPIC_API_KEY set above).
PATIENT_INTEL_DATA_PROVIDER=gemini
PATIENT_INTEL_ANALYZER_PROVIDER=gemini
PATIENT_INTEL_CAMPAIGN_PROVIDER=gemini

# ── Public URLs ─────────────────────────────────────
BASE_URL=https://your-domain.com

# ── Organization ────────────────────────────────────
DEFAULT_ORG_ID=your-org-uuid

# ── AI ad-image generation + S3 storage ─────────────
# Required in production once the feature ships.
# AD_IMAGE_DAILY_LIMIT=30
S3_BUCKET=tawafud-ad-images
S3_REGION=us-east-1
# S3_ENDPOINT=                       # optional: R2 / Spaces / MinIO
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME
S3_PUBLIC_URL_BASE=https://cdn.your-domain.com  # public CDN prefix
