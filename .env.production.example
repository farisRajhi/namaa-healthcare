# ============================================
# Tawafud Production Environment Variables
# Copy this to .env and fill in real values
# ============================================

# ── Database ─────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hospital_booking
POSTGRES_PORT=5434

# ── Redis ────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend ──────────────────────────────────────────
BACKEND_PORT=3000
LOG_LEVEL=info

# JWT Secret (MUST change in production — use: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET

# CORS (comma-separated allowed origins)
CORS_ORIGIN=https://your-domain.com

# Webhook API Key (for n8n → backend calls)
WEBHOOK_API_KEY=CHANGE_ME_RANDOM_KEY

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Public URLs ──────────────────────────────────────
BASE_URL=https://your-domain.com

# ── Organization ─────────────────────────────────────
DEFAULT_ORG_ID=your-org-uuid

# ── Frontend ─────────────────────────────────────────
FRONTEND_PORT=80

# ── n8n (optional, use with: docker compose --profile n8n up) ──
N8N_POSTGRES_PASSWORD=CHANGE_ME_N8N_PASSWORD

# ── Registration Protection (REQUIRED) ──────────────────
REGISTRATION_TOKEN=CHANGE_ME_RANDOM_TOKEN

# ── Tap Payments ────────────────────────────────────────
TAP_SECRET_KEY=sk_test_CHANGE_ME
TAP_PUBLIC_KEY=pk_test_CHANGE_ME
VITE_TAP_PUBLIC_KEY=pk_test_CHANGE_ME
