# ============================================
# Namaa Production Environment Variables
# Copy this to .env and fill in real values
# ============================================

# ── Database ─────────────────────────────────────────
POSTGRES_USER=app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=hospital_booking
POSTGRES_PORT=5434

# ── Redis ────────────────────────────────────────────
REDIS_PORT=6379

# ── Backend ──────────────────────────────────────────
BACKEND_PORT=3000
LOG_LEVEL=info

# JWT Secret (MUST change in production — use: openssl rand -base64 64)
JWT_SECRET=CHANGE_ME_GENERATE_STRONG_SECRET

# CORS (comma-separated allowed origins)
CORS_ORIGIN=https://your-domain.com

# Webhook API Key (for n8n → backend calls)
WEBHOOK_API_KEY=CHANGE_ME_RANDOM_KEY

# ── OpenAI ───────────────────────────────────────────
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4-turbo-preview
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7

# ── Google Gemini ────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key
USE_GEMINI_VOICE=true

# ── Twilio (Voice & WhatsApp) ────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+966xxxxxxxxx

# ── ElevenLabs TTS ───────────────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-api-key

# ── Voice Settings ───────────────────────────────────
VOICE_DEFAULT_DIALECT=msa
VOICE_MAX_CALL_DURATION_SEC=600
VOICE_SILENCE_TIMEOUT_MS=1500

# ── Public URLs ──────────────────────────────────────
BASE_URL=https://your-domain.com
VOICE_WS_URL=wss://your-domain.com/api/voice/stream

# ── Organization ─────────────────────────────────────
DEFAULT_ORG_ID=your-org-uuid

# ── Frontend ─────────────────────────────────────────
FRONTEND_PORT=80

# ── n8n (optional, use with: docker compose --profile n8n up) ──
N8N_POSTGRES_PASSWORD=CHANGE_ME_N8N_PASSWORD
